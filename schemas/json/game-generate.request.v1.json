{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axiomnode/game-generate.request.v1",
  "title": "GameGenerateRequestV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "language": {
      "type": "string",
      "default": "es"
    },
    "categoryId": {
      "type": "string",
      "minLength": 1
    },
    "categoryName": {
      "type": "string",
      "minLength": 1
    },
    "itemCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "description": "Canonical number of generated items requested"
    },
    "numQuestions": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "description": "Compatibility alias for itemCount"
    },
    "difficultyPercentage": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "letters": {
      "type": "string",
      "description": "Deprecated legacy letter constraint for older word-pass callers"
    },
    "requestedBy": {
      "type": "string",
      "enum": ["api", "backoffice"]
    }
  },
  "required": ["language"]
}
