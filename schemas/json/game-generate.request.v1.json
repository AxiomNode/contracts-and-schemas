{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axiomnode/game-generate.request.v1",
  "title": "GameGenerateRequestV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "language": {
      "type": "string",
      "default": "es"
    },
    "categoryId": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "numQuestions": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    }
  },
  "required": ["language"]
}
