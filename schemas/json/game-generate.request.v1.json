{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axiomnode/game-generate.request.v1",
  "title": "GameGenerateRequestV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "categoryId": {
      "type": "string",
      "minLength": 1
    },
    "categoryName": {
      "type": "string",
      "minLength": 1
    },
    "itemCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "description": "Number of generated items requested"
    },
    "difficultyPercentage": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "requestedBy": {
      "type": "string",
      "enum": ["api", "backoffice"]
    }
  }
}
