{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "game-generation-completed.v1.json",
  "title": "GameGenerationCompleted",
  "description": "Emitted when ai-engine successfully generates a game payload.",
  "type": "object",
  "required": ["event_type", "event_version", "correlation_id", "timestamp", "payload"],
  "additionalProperties": false,
  "properties": {
    "event_type": {
      "type": "string",
      "const": "game.generation.completed"
    },
    "event_version": {
      "type": "string",
      "const": "1.0"
    },
    "correlation_id": {
      "type": "string",
      "description": "Request correlation ID propagated from the originating HTTP request."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp of the event."
    },
    "payload": {
      "type": "object",
      "required": ["game_type", "cache_hit", "latency_ms", "distribution_version"],
      "additionalProperties": true,
      "properties": {
        "game_type": {
          "type": "string",
          "enum": ["quiz", "word-pass", "true_false"],
          "description": "Type of educational game generated."
        },
        "cache_hit": {
          "type": "boolean",
          "description": "Whether the response was served from cache."
        },
        "cache_layer": {
          "type": "string",
          "enum": ["memory", "persistent", "none"],
          "description": "Cache layer that produced the hit, or none."
        },
        "latency_ms": {
          "type": "number",
          "description": "Total end-to-end generation latency in milliseconds."
        },
        "distribution_version": {
          "type": "string",
          "description": "Deployment distribution+version tag (e.g. vps-cpu-v3)."
        },
        "prompt_version": {
          "type": "string",
          "description": "Version identifier of the prompt template used."
        },
        "input_tokens": {
          "type": ["integer", "null"],
          "description": "Estimated LLM input token count."
        },
        "output_tokens": {
          "type": ["integer", "null"],
          "description": "Estimated LLM output token count."
        }
      }
    }
  }
}
